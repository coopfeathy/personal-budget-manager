# Backend API environment variables
CORS_ORIGIN=https://your-netlify-site.netlify.app

# Netlify Database (shy-base-84793248)
# Use UNPOOLED for serverless functions.
NETLIFY_DATABASE_URL=postgres://<user>:<password>@<host>/<database>
NETLIFY_DATABASE_URL_UNPOOLED=postgres://<user>:<password>@<host>/<database>

# Legacy Mongo support (optional)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Aggregator provider variables for production (set in Netlify UI)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox
